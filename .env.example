DATABASE_URL=postgresql://fdih_user:fdih_password@localhost:5432/fdih_dev
DEMO_ORG_ID=00000000-0000-0000-0000-000000000001
PORT=3001
NODE_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:3001

# ─────────────────────────────────────────────────────────────────────────────
# AI Provider Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Supported providers: claude (default), gemini, modal

# AI Provider Selection
AI_PROVIDER=claude

# Claude (Anthropic) - Recommended
# Get API key from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-replace-me
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# Google Gemini - Fast and budget-friendly
# Get API key from: https://ai.google.dev
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Modal - Serverless execution with custom logic
# Get endpoint and token from: https://modal.com
MODAL_ENDPOINT=
MODAL_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
# File Storage Configuration (local or s3)
# ─────────────────────────────────────────────────────────────────────────────
STORAGE_TYPE=local
UPLOAD_DIR=./uploads

# AWS S3 Configuration (required if STORAGE_TYPE=s3)
AWS_REGION=ap-northeast-1
AWS_ENDPOINT=
AWS_BUCKET_NAME=fdih-documents
AWS_ACCESS_KEY_ID=your-access-key-here
AWS_SECRET_ACCESS_KEY=your-secret-access-key-here
AWS_SESSION_TOKEN=
